# OpenAI API Key
OPENAI_API_KEY=your-openai-api-key-here
GROQ_API_KEY=your-groq-api-key-here

# Pinecone API Key (optional)
PINECONE_API_KEY=your-pinecone-api-key-here

# HuggingFace API Key (optional)
HUGGINGFACE_API_KEY=your-huggingface-api-key-here

# API gateway auth key (recommended for non-local environments)
API_AUTH_KEY=change-this-to-a-long-random-value

# Allowed web origins (comma-separated)
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8501

# n8n basic auth
N8N_BASIC_AUTH_USER=n8n_admin
N8N_BASIC_AUTH_PASSWORD=change-this-password

# Embedding settings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Chunking settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Retriever settings
TOP_K=5

# LLM settings
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
